# Vite 環境変数（本番デプロイ時に設定）
# ローカル開発時は VITE_API_URL を空にすると Vite proxy (localhost:3000) を使用

# API Gateway の URL（例: https://xxxxxx.execute-api.ap-northeast-1.amazonaws.com/dev）
VITE_API_URL=

# Cognito HostedUI ドメイン（例: https://devflow-dev.auth.ap-northeast-1.amazoncognito.com）
VITE_COGNITO_DOMAIN=

# Cognito App Client ID
VITE_COGNITO_CLIENT_ID=
